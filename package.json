{
  "name": "benchdial",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:sandbox": "pnpm --dir sandbox-demo run build",
    "deploy:sandbox": "vercel deploy --prod --yes --project benchdial-sandbox --local-config sandbox-demo/vercel.json",
    "deploy:prod": "vercel deploy --prod --yes",
    "deploy:supabase": "powershell -ExecutionPolicy Bypass -File scripts/deploy-supabase.ps1",
    "verify:stack": "node scripts/verify-stack.mjs",
    "test": "vitest run && node scripts/check-agent-prompts.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.10.1",
    "@supabase/supabase-js": "^2.110.7",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "vitest": "latest"
  }
}
